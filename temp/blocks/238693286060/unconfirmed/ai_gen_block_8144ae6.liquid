{% doc %}
  @prompt
    A section with two columns. One with an image and the other one with an image and text with a button that takes user to a product.
    
    Both sides must be the same height. 
    
    Add multiple setting controls.
    
    The block must adopt the parent section background., Add padding settings for each side.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-{{ ai_gen_id }} {
    background: transparent;
    width: 100%;
  }

  .ai-two-column-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.column_gap }}px;
    align-items: stretch;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-two-column-left-{{ ai_gen_id }},
  .ai-two-column-right-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-two-column-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-two-column-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-two-column-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    height: 100%;
    {% if block.settings.content_vertical_alignment == 'top' %}
      justify-content: flex-start;
    {% elsif block.settings.content_vertical_alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
    {% if block.settings.content_horizontal_alignment == 'left' %}
      align-items: flex-start;
      text-align: left;
    {% elsif block.settings.content_horizontal_alignment == 'center' %}
      align-items: center;
      text-align: center;
    {% else %}
      align-items: flex-end;
      text-align: right;
    {% endif %}
  }

  .ai-two-column-content-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.content_image_max_width }}px;
    border-radius: {{ block.settings.content_image_border_radius }}px;
    overflow: hidden;
  }

  .ai-two-column-content-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-two-column-content-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-two-column-content-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-two-column-heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-two-column-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-two-column-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-two-column-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_column_gap }}px;
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
      padding-left: {{ block.settings.mobile_padding_left }}px;
      padding-right: {{ block.settings.mobile_padding_right }}px;
    }

    .ai-two-column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-two-column-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-two-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-container-{{ ai_gen_id }}">
    <div class="ai-two-column-left-{{ ai_gen_id }}">
      <div class="ai-two-column-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.left_image %}
          <img
            src="{{ block.settings.left_image | image_url: width: 1200 }}"
            alt="{{ block.settings.left_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.left_image.width }}"
            height="{{ block.settings.left_image.height }}"
            class="ai-two-column-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-two-column-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-two-column-empty-state-{{ ai_gen_id }}">
              Add left column image
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-two-column-right-{{ ai_gen_id }}">
      <div class="ai-two-column-content-{{ ai_gen_id }}">
        {% if block.settings.content_image %}
          <div class="ai-two-column-content-image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.content_image | image_url: width: 800 }}"
              alt="{{ block.settings.content_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.content_image.width }}"
              height="{{ block.settings.content_image.height }}"
              class="ai-two-column-content-image-{{ ai_gen_id }}"
            >
          </div>
        {% else %}
          <div class="ai-two-column-content-image-wrapper-{{ ai_gen_id }}">
            <div class="ai-two-column-content-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-two-column-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-two-column-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          {% if block.settings.product %}
            <a
              href="{{ block.settings.product.url }}"
              class="ai-two-column-button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% else %}
            <a
              href="#"
              class="ai-two-column-button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

