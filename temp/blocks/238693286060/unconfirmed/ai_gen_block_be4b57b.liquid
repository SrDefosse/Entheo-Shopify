{% doc %}
  @prompt
    A section with two columns. One with an image and the other one with a product and text with a button that takes user to the product.
    
    Both sides must be the same height. 
    
    Add multiple setting controls., The block must adopt the parent section background, Product image and content must be centered, and customizable., I should be able to decide if the price is visible or not
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-two-column-container-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    gap: {{ block.settings.column_gap }}px;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  {% if block.settings.layout == 'image_left' %}
    .ai-two-column-container-{{ ai_gen_id }} {
      flex-direction: row;
    }
  {% else %}
    .ai-two-column-container-{{ ai_gen_id }} {
      flex-direction: row-reverse;
    }
  {% endif %}

  .ai-two-column-image-wrapper-{{ ai_gen_id }},
  .ai-two-column-content-wrapper-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-two-column-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-two-column-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-two-column-content-wrapper-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.content_alignment }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-two-column-product-image-{{ ai_gen_id }} {
    width: {{ block.settings.product_image_size }}px;
    height: {{ block.settings.product_image_size }}px;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_border_radius }}px;
    margin-bottom: 20px;
  }

  .ai-two-column-product-image-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.product_image_size }}px;
    height: {{ block.settings.product_image_size }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.product_image_border_radius }}px;
    margin-bottom: 20px;
  }

  .ai-two-column-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
  }

  .ai-two-column-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-two-column-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
  }

  .ai-two-column-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin-bottom: 24px;
  }

  .ai-two-column-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-two-column-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-two-column-empty-product-{{ ai_gen_id }} {
    font-size: 14px;
    color: #999;
    padding: 20px;
    text-align: center;
    font-style: italic;
  }

  @media screen and (max-width: 768px) {
    .ai-two-column-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.column_gap | times: 0.5 }}px;
    }

    .ai-two-column-image-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-two-column-content-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }

    .ai-two-column-product-image-{{ ai_gen_id }},
    .ai-two-column-product-image-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.product_image_size | times: 0.8 }}px;
      height: {{ block.settings.product_image_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-two-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-container-{{ ai_gen_id }}">
    <div class="ai-two-column-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-two-column-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-two-column-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-two-column-empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-two-column-content-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product != blank %}
        {% assign product = block.settings.product %}
        
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 400 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            width="400"
            height="400"
            class="ai-two-column-product-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-two-column-product-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        <h3 class="ai-two-column-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
        
        {% if block.settings.show_price %}
          <div class="ai-two-column-product-price-{{ ai_gen_id }}">
            {{ product.price | money }}
          </div>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-two-column-text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}

        <a
          href="{{ product.url }}"
          class="ai-two-column-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% else %}
        <div class="ai-two-column-empty-product-{{ ai_gen_id }}">
          Select a product to display
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Two column product",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "image_left",
          "label": "Image left"
        },
        {
          "value": "image_right",
          "label": "Image right"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Column gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Image column"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content column"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Content padding",
      "default": 40
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "product_image_size",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Product image size",
      "default": 120
    },
    {
      "type": "range",
      "id": "product_image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Product image border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Product title size",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Product price size",
      "default": 18
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover our featured product with exceptional quality and design.</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 14
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Hover background color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Two column product"
    }
  ]
}
{% endschema %}