      "label": "Vertical offset",
      "default": 4
    },
    {
      "type": "range",
      "id": "glass_shadow_blur",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Blur",
      "default": 20
    },
    {
      "type": "color",
      "id": "glass_shadow_color",
      "label": "Shadow color",
      "default": "rgba(0, 0, 0, 0.1)"
    },
    {
      "type": "header",
      "content": "Form container"
    },
    {
      "type": "range",
      "id": "form_padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_form_padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Mobile padding",
      "default": 25
    },
    {
      "type": "range",
      "id": "field_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Field gap",
      "default": 20
    },
    {
      "type": "header",
      "content": "Form labels"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Name label",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "vision_label",
      "label": "Vision label",
      "default": "Your Vision"
    },
    {
      "type": "text",
      "id": "budget_label",
      "label": "Budget label",
      "default": "Approximate Budget"
    },
    {
      "type": "checkbox",
      "id": "show_required_asterisk",
      "label": "Show required asterisk",
      "default": true
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "required_color",
      "label": "Required asterisk color",
      "default": "#d82c0d"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
