    {
      "type": "color",
      "id": "left_background_color",
      "label": "Background color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "left_column_padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_left_column_padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Mobile padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "left_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Content gap",
      "default": 20
    },
    {
